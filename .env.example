# =============================================================================
# AthleteX environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# =============================================================================

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ----- Supabase -----
# From https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# SERVER-ONLY. Never expose to client. Used in route handlers + admin scripts.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# ----- Upstash Redis (rate limit + ephemeral) -----
# Free tier at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ----- Resend (transactional email) -----
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM_EMAIL="AthleteX <noreply@athletex.app>"

# ----- Stripe (premium subscription, web/PWA) -----
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY

# ----- SportsRadar (Phase 1 dev tier) -----
# Free dev key: https://developer.sportradar.com
SPORTRADAR_API_KEY=YOUR_DEV_KEY
SPORTRADAR_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ----- PostHog (analytics, EU region) -----
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ----- Cloudflare Turnstile (bot mitigation on signup) -----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_SECRET

# ----- Optional: encryption key for PII column (Phase 2) -----
# 32-byte base64. Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# ----- HMAC secret for signing waitlist session/verification tokens -----
# 32-byte base64. Generate: openssl rand -base64 32
APP_WAITLIST_SECRET=
